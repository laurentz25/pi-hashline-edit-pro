    "test:watch": "vitest"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@types/node": "^22.0.0",
    "@types/xxhashjs": "^0.2.4",
    "ajv": "^8.20.0",
